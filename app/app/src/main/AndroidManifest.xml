<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- жқғйҷҗеЈ°жҳҺ -->
    <!-- зҪ‘з»ңжқғйҷҗ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- еҪ•йҹіжқғйҷҗ -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    
    <!-- еүҚеҸ°жңҚеҠЎжқғйҷҗ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    
    <!-- йҖҡзҹҘжқғйҷҗ (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- е”ӨйҶ’й”ҒжқғйҷҗпјҲдҝқжҢҒжңҚеҠЎиҝҗиЎҢпјү -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- ејҖжңәиҮӘеҗҜеҠЁ -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- еӯҳеӮЁжқғйҷҗ -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".DailyMateApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@android:drawable/ic_btn_speak_now"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DailyMate"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">
        
        <!-- дё»Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DailyMate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- и®°еҪ•жҹҘзңӢActivity -->
        <activity
            android:name=".RecordsActivity"
            android:exported="false"
            android:theme="@style/Theme.DailyMate" />

        <!-- иҜӯйҹізӣ‘еҗ¬еүҚеҸ°жңҚеҠЎ - ж ҮеҮҶжЁЎејҸ -->
        <service
            android:name=".service.VoiceRecordingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- иҜӯйҹізӣ‘еҗ¬еүҚеҸ°жңҚеҠЎ - иҝһз»ӯжЁЎејҸ -->
        <service
            android:name=".service.ContinuousVoiceRecordingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- ејҖжңәиҮӘеҗҜеҠЁжҺҘж”¶еҷЁ -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- ж–Үд»¶жҸҗдҫӣиҖ… -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
